      "source": [
        "original_bgr_image = cv2.imread('/content/Screenshot 2026-07-03 111935.png')\n",
        "\n",
        "# Check if image was loaded successfully\n",
        "if original_bgr_image is None:\n",
        "    print(\"Error: Could not load image. Check the file path.\")\n",
        "else:\n",
        "    # Create a copy of the original image to draw lines on\n",
        "    image_with_lines = original_bgr_image.copy()\n",
        "\n",
        "    gray_image = cv2.cvtColor(original_bgr_image, cv2.COLOR_BGR2GRAY)\n",
        "    edges = cv2.Canny(gray_image, 50, 150, apertureSize=3)\n",
        "    lines = cv2.HoughLines(edges, 1, np.pi/180, 200)\n",
        "\n",
        "    if lines is not None:\n",
        "        for rt in lines:\n",
        "            for rho, theta in rt:\n",
        "                a = np.cos(theta)\n",
        "                b = np.sin(theta)\n",
        "                x0 = a*rho\n",
        "                y0 = b*rho\n",
        "                x1 = int(x0 + 1000*(-b))\n",
        "                y1 = int(y0 + 1000*(a))\n",
        "                x2 = int(x0 - 1000*(-b))\n",
        "                y2 = int(y0 - 1000*(a))\n",
        "                # Draw a red line on the BGR image\n",
        "                cv2.line(image_with_lines, (x1,y1), (x2,y2), (0,0,255), 2)\n",
        "\n",
        "    fig = plt.figure(figsize=(10, 4))\n",
        "    ax1 = fig.add_subplot(121)\n",
        "    ax2 = fig.add_subplot(122)\n",
        "\n",
        "    # Convert BGR images to RGB for matplotlib display\n",
        "    ax1.imshow(cv2.cvtColor(original_bgr_image, cv2.COLOR_BGR2RGB))\n",
        "    ax1.title.set_text('Original Image')\n",
        "    ax2.imshow(cv2.cvtColor(image_with_lines, cv2.COLOR_BGR2RGB))\n",
        "    ax2.title.set_text('Hough Lines on Original Image')\n",
        "    plt.show()"
